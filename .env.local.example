# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── App URL ──────────────────────────────────────────────────────────────────
# The public URL of your deployed app (used in invite email links)
# Example: https://family-finance.vercel.app  or  http://localhost:3000
NEXT_PUBLIC_APP_URL=https://your-app-url.com

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# The email address that receives bill reminder notifications
REMINDER_TO_EMAIL=you@example.com

# ─── Scheduled Reminders ──────────────────────────────────────────────────────
# A secret token to protect the /api/reminders cron endpoint.
# Generate one with: openssl rand -base64 32
# Then configure your cron job to send: Authorization: Bearer <this-value>
CRON_SECRET=your_random_secret_here
